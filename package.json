{
  "name": "hmkconf",
  "private": true,
  "version": "1.8.0",
  "productName": "hmkconf",
  "description": "Desktop configurator for libhmk keyboards.",
  "author": {
    "name": "satoyu"
  },
  "main": "electron/main.mjs",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "bun run scripts/vite-build.mjs",
    "preview": "vite preview",
    "desktop:start": "electron .",
    "desktop:dev": "bun run scripts/electron-dev.mjs",
    "desktop": "bun run build && bun run desktop:start",
    "desktop:dist:linux": "bun run build && env -u DEBUG VITEST=1 ELECTRON_BUILDER_CACHE=/tmp/hmkconf-electron-builder-cache XDG_CACHE_HOME=/tmp electron-builder --linux AppImage --publish never",
    "desktop:dist:win": "bun run build && electron-builder --win nsis --publish never",
    "desktop:dist:mac": "bun run build && electron-builder --mac dmg --publish never",
    "tauri": "tauri",
    "package": "svelte-kit sync && svelte-package && publint",
    "prepublishOnly": "npm run package",
    "test": "vitest",
    "test:unit": "vitest",
    "check": "svelte-kit sync && bun run scripts/run-svelte-check.mjs --tsconfig ./tsconfig.json",
    "check:interop": "bun scripts/check_libhmk_metadata_interop.ts",
    "check:watch": "svelte-kit sync && bun run scripts/run-svelte-check.mjs --tsconfig ./tsconfig.json --watch",
    "format": "prettier --write .",
    "lint": "prettier --check . && eslint .",
    "sync-types": "python ../libhmk/scripts/gen_ts_types.py ../libhmk/include/common.h ../libhmk/include/rgb.h ../libhmk/include/joystick.h ../libhmk/include/eeconfig.h src/lib/libhmk/generated/eeconfig.ts",
    "gen-rgb-coords": "python ../libhmk/scripts/gen_rgb_coords.py ../libhmk/keyboards/mochiko40he",
    "update-demo-metadata": "bun scripts/update_demo_metadata.js",
    "sync-all": "bun run gen-rgb-coords && bun run update-demo-metadata && bun run sync-types"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.0",
    "@eslint/js": "^9.39.2",
    "@ianvs/prettier-plugin-sort-imports": "^4.7.0",
    "@internationalized/date": "^3.10.1",
    "@lucide/svelte": "^0.562.0",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/adapter-vercel": "^6.2.0",
    "@sveltejs/kit": "^2.49.2",
    "@sveltejs/vite-plugin-svelte": "^6.2.1",
    "@tailwindcss/vite": "^4.1.18",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/cli": "^2.10.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.3.1",
    "@types/w3c-web-hid": "^1.0.6",
    "bits-ui": "^2.14.4",
    "clsx": "^2.1.1",
    "electron": "^40.1.0",
    "electron-builder": "^26.0.12",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-svelte": "^3.13.1",
    "globals": "^16.5.0",
    "jsdom": "^28.1.0",
    "paneforge": "^1.0.2",
    "prettier": "^3.7.4",
    "prettier-plugin-svelte": "^3.4.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "svelte": "^5.46.1",
    "svelte-check": "^4.3.5",
    "svelte-sonner": "^1.0.7",
    "tailwind-merge": "^3.4.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.1.18",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.51.0",
    "vite": "^7.3.0",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.8",
    "@fontsource-variable/geist-mono": "^5.2.7",
    "mode-watcher": "^1.1.0",
    "runed": "^0.37.1",
    "zod": "^4.2.1"
  },
  "build": {
    "appId": "com.hmkconf.app",
    "productName": "hmkconf",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "build/**/*",
      "electron/**/*",
      "package.json"
    ],
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Utility",
      "icon": "src-tauri/icons"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "src-tauri/icons/icon.ico"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.utilities",
      "icon": "src-tauri/icons/icon.icns"
    },
    "electronDist": "node_modules/electron/dist",
    "asar": true,
    "artifactName": "${productName}-${version}-${arch}.${ext}"
  }
}
